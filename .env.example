# Application
NODE_ENV=development
APP_PORT=3000
APP_HOST=localhost
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=assetflow
DB_USER=assetflow_user
DB_PASSWORD=assetflow_secure_password_change_this
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# File Upload
MAX_FILE_SIZE_MB=5
ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf
UPLOAD_DIR=./uploads

# Email (for forgot password, notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@assetflow.com

# Audit & Activity Logging
ENABLE_ACTIVITY_LOGGING=true
ACTIVITY_LOG_TABLE=activity_log

# Feature Flags
ENABLE_SSE_NOTIFICATIONS=true
SSE_HEARTBEAT_INTERVAL=30
ENABLE_AUDIT_CYCLES=true
